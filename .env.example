# ─────────────────────────────────────────────────────────────
# Aurora Hub — backend environment (copy to backend/.env)
# ─────────────────────────────────────────────────────────────

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=aurora_hub

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,capacitor://localhost,http://localhost,https://localhost

# ── LLM providers (authoring plane only; not used on the serving hot path) ──
# Which provider generates new questions, and which independently cross-checks
# them. Generator and verifier SHOULD differ so the re-solve is independent.
# Default stack: Gemini generates + embeds, Groq cross-checks.
# Embeddings must be gemini — Groq and Claude have no embeddings API.
LLM_GENERATOR_PROVIDER=gemini      # gemini | groq | claude
LLM_VERIFIER_PROVIDER=groq         # gemini | groq | claude
LLM_EMBEDDING_PROVIDER=gemini      # gemini  (only provider with embeddings here)
# Cheap categorize/parse path for bulk ingestion. Empty = use the generator.
# Tip: Gemini's free tier is only ~20 requests/day — point this at Groq for bulk.
LLM_PARSER_PROVIDER=               # gemini | groq | claude  (empty = generator)

# Provider API keys (fill the ones you use)
GEMINI_API_KEY=                    # Google AI Studio
GROQ_API_KEY=
# ANTHROPIC_API_KEY=               # optional; only if a provider above = claude

# Model names
# Note: gemini-2.5-pro has little/no free-tier quota (429); flash is generous.
# Embeddings: gemini-embedding-001 (text-embedding-004 is not served on this API).
GEMINI_GENERATION_MODEL=gemini-2.5-flash
GEMINI_EMBEDDING_MODEL=gemini-embedding-001
GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
GROQ_VERIFIER_MODEL=llama-3.3-70b-versatile
# CLAUDE_GENERATION_MODEL=claude-opus-4-8
# CLAUDE_VERIFIER_MODEL=claude-opus-4-8

# ── Dedup ──
# Reject a generated question if cosine similarity to any exemplar/existing
# item in the same subtopic exceeds this threshold.
DEDUP_SIMILARITY_THRESHOLD=0.92

# ─────────────────────────────────────────────────────────────
# Frontend — copy the line below into frontend/.env.local
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
