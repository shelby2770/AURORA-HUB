# ─────────────────────────────────────────────────────────────
# Aurora Hub — backend environment (copy to backend/.env)
# ─────────────────────────────────────────────────────────────

# MongoDB
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=aurora_hub

# CORS — comma-separated origins allowed to call the API
CORS_ORIGINS=http://localhost:3000,capacitor://localhost,http://localhost

# ── LLM providers (authoring plane only; not used on the serving hot path) ──
# Which provider generates new questions, and which independently cross-checks them.
# Generator and verifier may differ (e.g. gemini generates, claude verifies).
LLM_GENERATOR_PROVIDER=gemini      # gemini | claude
LLM_VERIFIER_PROVIDER=claude       # gemini | claude
LLM_EMBEDDING_PROVIDER=gemini      # gemini | claude

# Provider API keys
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Model names
GEMINI_GENERATION_MODEL=gemini-2.5-pro
GEMINI_EMBEDDING_MODEL=text-embedding-004
CLAUDE_GENERATION_MODEL=claude-opus-4-8
CLAUDE_VERIFIER_MODEL=claude-opus-4-8

# ── Dedup ──
# Reject a generated question if cosine similarity to any exemplar/existing
# item in the same subtopic exceeds this threshold.
DEDUP_SIMILARITY_THRESHOLD=0.92

# ─────────────────────────────────────────────────────────────
# Frontend — copy the line below into frontend/.env.local
# ─────────────────────────────────────────────────────────────
# NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
